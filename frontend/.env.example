# Copy this file to `.env.local` in this same directory (frontend project root).
# Next.js loads `.env.local` automatically; do not put secrets under `.next/`.
#
# Firebase Web app (client SDK) — Firebase Console → Project settings → Your apps → Web app.
# Required for sign-in: apiKey + projectId (see `src/lib/firebase/client.ts`).
# NEXT_PUBLIC_* is exposed to the browser; use only the Web config from the Firebase snippet.
# Service account JSON / private keys are for the Python backend only — never add them here.
#
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Optional — if omitted, authDomain defaults to {projectId}.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional — proxy routes to FastAPI. In development, defaults to http://127.0.0.1:8000 if unset.
# BACKEND_API_URL=

# Gmail OAuth: backend `GOOGLE_REDIRECT_URI` + Google Cloud "Authorized redirect URIs" must match exactly.
# Option A — Google redirects straight to the API:
#   http://127.0.0.1:8000/integrations/gmail/callback
# Option B — Google redirects to Next (this repo proxies to the API). Example for port 3001:
#   http://127.0.0.1:3001/api/integrations/gmail/callback
# Use the same string in all three places (backend .env, Google Console, no trailing slash mismatch).
