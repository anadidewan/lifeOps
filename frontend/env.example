# Client Firebase config (Firebase Console → Project settings → Your apps → Web app)
# Use the same project as life-os-backend (FIREBASE_PROJECT_ID must match projectId).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Optional: FastAPI base URL to call POST /auth/verify-token after sign-in (creates/syncs app user)
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
